generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  TEACHER
  PARENT
}

enum VisualCondition {
  NONE
  PROTANOPIA
  TRITANOPIA
  LOW_VISION
}

enum AuditoryCondition {
  NONE
  HARD_OF_HEARING
  DEAF
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())

  firstName     String
  lastNameP     String
  lastNameM     String?

  createdById   Int?
  createdBy     User?     @relation("TeacherStudents", fields: [createdById], references: [id])
  studentsCreated User[]  @relation("TeacherStudents")

  studentProfile StudentProfile?
  results       GameResult[]
}

model StudentProfile {
  id                  Int               @id @default(autoincrement())
  userId               Int               @unique
  visualCondition      VisualCondition   @default(NONE)
  auditoryCondition    AuditoryCondition @default(NONE)
  fontScale            Int               @default(100)
  highContrast         Boolean           @default(false)
  textToSpeechEnabled  Boolean           @default(false)
  voiceInstructions    Boolean           @default(false)
  captionsEnabled      Boolean           @default(true)
  visualAlertsEnabled  Boolean           @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameResult {
  id         Int      @id @default(autoincrement())
  userId     Int
  game       String
  score      Int
  moves      Int
  durationMs Int
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
